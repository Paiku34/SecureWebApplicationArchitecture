# ============================================
# PROTEZIONE CARTELLA STORAGE
# ============================================
# Questa cartella contiene:
# - /uploads/audio/ - File audio caricati dagli utenti
# - /uploads/lyrics/ - File testo caricati dagli utenti
# - /logs/ - Log di sicurezza (security.log)
#
# L'accesso diretto via URL è BLOCCATO.
# I file vengono serviti SOLO tramite download.php (con autenticazione)
# ============================================

# 1. BLOCCO ACCESSO COMPLETO (Apache 2.4+)
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# 1b. Fallback per Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# 2. DISABILITA LISTING DIRECTORY
# Anche se il blocco venisse bypassato, non si vedrebbe la lista file
Options -Indexes

# 3. DISABILITA ESECUZIONE PHP
# Protezione critica: se un attaccante caricasse un file .php.mp3
# rinominandolo poi in .php, il server NON lo eseguirebbe
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# 4. BLOCCA FILE NASCOSTI E DI SISTEMA
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 5. FORZA DOWNLOAD (impedisce interpretazione nel browser)
<IfModule mod_headers.c>
    <FilesMatch ".*">
        Header set Content-Disposition attachment
        Header set X-Content-Type-Options nosniff
    </FilesMatch>
</IfModule>

# 6. BLOCCA TIPI FILE PERICOLOSI (doppia protezione)
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phar|inc|pl|py|cgi|sh|bash|exe|bat|cmd)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
