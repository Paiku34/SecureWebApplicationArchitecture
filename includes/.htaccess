# 1. Compatibilità con Apache 2.4+ e versioni precedenti
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# 2. Impedisce il listing delle cartelle
# Se qualcuno riuscisse a bypassare il blocco, non vedrebbe comunque la lista dei file
Options -Indexes

# 3. Disabilita l'esecuzione di script PHP (Protezione definitiva contro Web Shell)
# Anche se un hacker caricasse un file .php rinominato, il server si rifiuterebbe di eseguirlo
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# 4. Forza il download per tutti i file (Fallback di sicurezza)
# Impedisce al browser di provare a interpretare i file come HTML o Script
<FilesMatch ".*">
    Header set Content-Disposition attachment
    Header set X-Content-Type-Options nosniff
</FilesMatch>

# 5. Blocca l'accesso a file di sistema o nascosti
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Blocca accesso completo alla cartella logs
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Doppia protezione: disabilita PHP
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

Options -Indexes